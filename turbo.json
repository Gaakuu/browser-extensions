{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**"]
    },
    "zip": {
      "dependsOn": ["build"],
      "outputs": [".output/**/*.zip"]
    },
    "test": {
      "cache": false
    }
  }
}
